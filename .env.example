# Recro Group - Environment Variables Example
# ----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in your values.
# Never commit real secrets. .env* is gitignored.
#
# Required for local development and production.

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# PostgreSQL connection string used by Prisma.
# Examples:
#   Local:   postgresql://postgres:postgres@localhost:5432/recro?schema=public
#   Neon:    postgresql://user:pass@ep-xxx.region.aws.neon.tech/recro?sslmode=require
#   Render/Supabase/etc: use the provider's full connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recro?schema=public"

# ----------------------------------------------------------------------------
# BETTER AUTH (Authentication)
# ----------------------------------------------------------------------------
# Secret used for signing sessions, tokens, and encryption.
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 32
#   or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# Public base URL of your app (used for generating links in emails, redirects, etc.).
# Local development:  http://localhost:3000
# Production example: https://your-domain.com
BETTER_AUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# DEVELOPMENT HELPERS (optional)
# ----------------------------------------------------------------------------
# DEV_PORTAL_ROLE
# When running in development (NODE_ENV=development) AND BETTER_AUTH_SECRET
# is not set, the portal will automatically log you in as this role.
# Useful for UI development without a real database/auth setup.
#
# Allowed values: admin | receptionist | customer
# Default (if unset): admin
DEV_PORTAL_ROLE="admin"

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# - NODE_ENV is automatically set by Next.js (development / production / test).
# - No email sending provider is configured yet. When password reset emails,
#   email verification, etc. are wired up (via Better Auth's sendResetPassword
#   etc.), additional variables such as RESEND_API_KEY or SMTP_* will be needed.
# - The contact form, M-Pesa integration, and many portal features currently
#   use mock data or are not yet connected to real backends.
# - For production deployments (Vercel, etc.), set the same variables in the
#   platform's environment variable dashboard.
